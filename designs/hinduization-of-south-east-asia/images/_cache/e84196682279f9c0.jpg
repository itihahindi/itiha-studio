orld-_2013-10-30_10-55.png/250px-Om%2C_This_the_first_word_in_the_world-_2013-10-30_10-55.png 2x" data-file-width="356" data-file-height="366" /></a></span></td></tr><tr><td colspan="2" class="infobox-image"><span typeof="mw:File"><a href="/wiki/File:Hinduism_Expansion_in_Asia.svg" class="mw-file-description"><img src="//upload.wikimedia.org/wikipedia/commons/thumb/0/05/Hinduism_Expansion_in_Asia.svg/250px-Hinduism_Expansion_in_Asia.svg.png" decoding="async" width="250" height="187" class="mw-file-element" srcset="//upload.wikimedia.org/wikipedia/commons/thumb/0/05/Hinduism_Expansion_in_Asia.svg/500px-Hinduism_Expansion_in_Asia.svg.png 2x" data-file-width="512" data-file-height="382" /></a></span><div class="infobox-caption">Expansion of <a href="/wiki/Hinduism" title="Hinduism">Hinduism</a> in Southeast Asia</div></td></tr><tr><th colspan="2" class="infobox-header" style="background-color: #d2ccb9; color:inherit;">Total population</th></tr><tr><td colspan="2" class="infobox-full-data"><a href="https://en.wiktionary.org/wiki/circa#English" class="extiw" title="wikt:circa">c.</a><span style="white-space:nowrap;">&#8201;<b>7,933,717</b></span><span typeof="mw:File"><span title="Increase"><img alt="Increase" src="//upload.wikimedia.org/wikipedia/commons/thumb/b/b0/Increase2.svg/20px-Increase2.svg.png" decoding="async" width="11" height="11" class="mw-file-element" srcset="//upload.wikimedia.org/wikipedia/commons/thumb/b/b0/Increase2.svg/40px-Increase2.svg.png 2x" data-file-width="300" data-file-height="300" /></span></span>
<br />(1.40% of the population)</td></tr><tr><th colspan="2" class="infobox-header" style="background-color: #d2ccb9; color:inherit;">Regions with significant populations</th></tr><tr><th scope="row" class="infobox-label"><a href="/wiki/Hinduism_in_Indonesia" title="Hinduism in Indonesia">Indonesia</a></th><td class="infobox-data">4,646,357<sup id="cite&#95;ref-2" class="reference"><a href="#cite_note-2"><span class="cite-bracket">&#91;</span>2<span class="cite-bracket">&#93;</span></a></sup></td></tr><tr><th scope="row" class="infobox-label"><a href="/wiki/Hinduism_in_Malaysia" title="Hinduism in Malaysia">Malaysia</a></th><td class="infobox-data">1,949,850<sup id="cite&#95;ref-3" class="reference"><a href="#cite_note-3"><span class="cite-bracket">&#91;</span>3<span class="cite-bracket">&#93;</span></a></sup></td></tr><tr><th scope="row" class="infobox-label"><a href="/wiki/Hinduism_in_Myanmar" title="Hinduism in Myanmar">Myanmar</a></th><td class="infobox-data">820,000<sup id="cite&#95;ref-4" class="reference"><a href="#cite_note-4"><span class="cite-bracket">&#91;</span>4<span class="cite-bracket">&#93;</span></a></sup></td></tr><tr><th scope="row" class="infobox-label"><a href="/wiki/Hinduism_in_Singapore" title="Hinduism in Singapore">Singapore</a></th><td class="infobox-data">372,963</td></tr><tr><th scope="row" class="infobox-label"><a href="/wiki/Hinduism_in_Thailand" title="Hinduism in Thailand">Thailand</a></th><td class="infobox-data">84,000<sup id="cite&#95;ref-5" class="reference"><a href="#cite_note-5"><span class="cite-bracket">&#91;</span>5<span class="cite-bracket">&#93;</span></a></sup></td></tr><tr><th scope="row" class="infobox-label"><a href="/wiki/Hinduism_in_the_Philippines" title="Hinduism in the Philippines">Philippines</a></th><td class="infobox-data">34,634<sup id="cite&#95;ref-auto&#95;6-0" class="reference"><a href="#cite_note-auto-6"><span class="cite-bracket">&#91;</span>6<span class="cite-bracket">&#93;</span></a></sup></td></tr><tr><