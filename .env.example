# Copy to .env and fill in. See docs/INSTAGRAM_SETUP.md.

# Instagram Graph API
IG_USER_ID=
IG_ACCESS_TOKEN=

# Where to host PNGs so Instagram can fetch them. Choose one strategy.
# Options: cloudinary | tunnel
IMAGE_HOST=cloudinary

# If IMAGE_HOST=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# If IMAGE_HOST=tunnel (e.g. cloudflared serving designs/<name>/output/)
TUNNEL_PUBLIC_URL=

# ── Notion sync (optional) ───────────────────────────────────
# If both are set, the Studio home page shows a "Notion backlog" section
# pulled from your Instagram Content Plan database. Clicking a row creates
# a Studio project + writes back the slug + bumps status to "Write Post".
# After a successful render, status → "Ready to publish" and slide-1.png
# is attached to the Notion row's Image File property.
#
# How to set up (5 min):
#   1. Go to https://www.notion.so/profile/integrations → New integration
#      → name it "Itiha Studio" → Internal → copy the secret (starts with `secret_`).
#   2. Open your Instagram Content Plan database in Notion → "..." menu →
#      Connections → add the Itiha Studio integration.
#   3. Copy the database ID from the URL: notion.so/<workspace>/<DB_ID>?v=...
#      It's a 32-char hex (UUID).

NOTION_TOKEN=
NOTION_DB_ID=

